{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "drizzle-kit push --config ./drizzle.config.ts && pnpm run apply-sql",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts && pnpm run apply-sql",
    "generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "migrate": "tsx ./scripts/migrate.ts",
    "apply-sql": "tsx ./scripts/apply-sql.ts",
    "seed-admin": "tsx ./scripts/seed-admin.ts"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "catalog:"
  }
}

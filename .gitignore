# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ─── Environment / secrets ────────────────────────────────────────────
# NEVER commit these. All env vars must be referenced via process.env.X
# and documented in README.md.
.env
.env.*
!.env.example
.envrc

# ─── Compiled output ──────────────────────────────────────────────────
dist
build
out
out-tsc
tmp
*.tsbuildinfo
.expo
.expo-shared
.next
.nuxt
.turbo
.vite
.parcel-cache

# ─── Dependencies ─────────────────────────────────────────────────────
node_modules
.pnp
.pnp.js

# ─── Local databases / dev artefacts ──────────────────────────────────
*.sqlite
*.sqlite-journal
*.db
*.db-journal
pgdata/

# ─── IDE / editor ─────────────────────────────────────────────────────
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ─── Misc ─────────────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings
*.log
logs/

# ─── System files ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Nx / monorepo cache ──────────────────────────────────────────────
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ─── Replit-specific ──────────────────────────────────────────────────
# These configure the Replit dev environment and are not portable.
.cache/
.local/
.replit
replit.nix
.replitignore
.upm/
.config/
.breakpoints

# ─── Internal session artefacts ───────────────────────────────────────
# Pasted user messages and other agent-session detritus
attached_assets/
